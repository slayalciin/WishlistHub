</div></div><script id="ModalScriptYta">
	var openEls2 = document.querySelectorAll("[data-open]");
	var closeEls2 = document.querySelectorAll("[data-close]");
	var isVisible2 = "is-visible";
	for (var el of openEls2) {
	  el.addEventListener("click", function() {
		var modalId = this.dataset.open;
		document.getElementById(modalId).classList.add(isVisible2);
	  });
	}
	for (var el of closeEls2) {
	  el.addEventListener("click", function() {
		//shutdown with x icon
		document.querySelector(".yta-modal.is-visible").classList.remove(isVisible2);
	  });
	}
	
	// Gallery navigation event listeners
	document.addEventListener("click", function(e) {
		
		// Check if clicked element or its parent is a navigation button
		var target = e.target;
		var navButton = null;
		
		// Check multiple levels up for the navigation button
		var currentElement = target;
		while (currentElement && currentElement !== document) {
			if (currentElement.classList && (currentElement.classList.contains("yta-gallery-prev") || currentElement.classList.contains("yta-gallery-next"))) {
				navButton = currentElement;
				break;
			}
			currentElement = currentElement.parentElement;
		}
		
		if (navButton) {
	
			if (navButton.classList.contains("yta-gallery-prev")) {
				var galleryId = navButton.getAttribute("data-gallery-id");
				var mediaFiles = JSON.parse(navButton.getAttribute("data-media-files"));
				// Find the modal that contains this gallery
				var modal = document.querySelector(".yta-modal-content-div");	
				if (modal) {
					// Find all images in the modal
					var allImages = modal.querySelectorAll("img");
					// Find the main image (not thumbnail)
					var mainImg = null;
					for (var i = 0; i < allImages.length; i++) {
						var img = allImages[i];
						
						// Skip thumbnails
						if (!img.classList.contains("yta-gallery-thumb")) {
							mainImg = img;
							break;
						}
					}
					
					if (mainImg) {
						var currentIndex = parseInt(mainImg.getAttribute("data-current-index")) || 0;
						var newIndex = currentIndex > 0 ? currentIndex - 1 : mediaFiles.length - 1;

						// Try multiple approaches to change the image
						var newSrc = mediaFiles[newIndex].url;
						
						// Method 1: Direct src change
						mainImg.src = newSrc;
						mainImg.setAttribute("src", newSrc);
						mainImg.setAttribute("data-current-index", newIndex);
						
						// Method 2: Create new image element
						var newImg = document.createElement("img");
						newImg.src = newSrc;
						newImg.className = mainImg.className;
						newImg.id = mainImg.id;
						newImg.setAttribute("data-current-index", newIndex);
						newImg.setAttribute("data-gallery-id", galleryId);
						
						// Copy all attributes
						for (var j = 0; j < mainImg.attributes.length; j++) {
							var attr = mainImg.attributes[j];
							if (attr.name !== "src" && attr.name !== "data-current-index") {
								newImg.setAttribute(attr.name, attr.value);
							}
						}
						
						// Replace the old image with new one
						mainImg.parentNode.replaceChild(newImg, mainImg);
						
						
						// Update thumbnails
						var thumbnails = document.querySelectorAll('[data-gallery-id="' + galleryId + '"]');
						thumbnails.forEach(function(thumb, index) {
							if (thumb.classList.contains("yta-gallery-thumb")) {
								thumb.classList.toggle("active", index === newIndex);
								thumb.style.border = index === newIndex ? "2px solid #333" : "2px solid transparent";
							}
						});
					} 
				} 
			}
			
			if (navButton.classList.contains("yta-gallery-next")) {
				var galleryId = navButton.getAttribute("data-gallery-id");
				var mediaFiles = JSON.parse(navButton.getAttribute("data-media-files"));

				// Find the modal that contains this gallery
				var modal = document.querySelector(".yta-modal-content-div");
				
				if (modal) {
					// Find all images in the modal
					var allImages = modal.querySelectorAll("img");
					
					// Find the main image (not thumbnail)
					var mainImg = null;
					for (var i = 0; i < allImages.length; i++) {
						var img = allImages[i];

						// Skip thumbnails
						if (!img.classList.contains("yta-gallery-thumb")) {
							mainImg = img;
							break;
						}
					}
					
					if (mainImg) {
						var currentIndex = parseInt(mainImg.getAttribute("data-current-index")) || 0;
						var newIndex = currentIndex < mediaFiles.length - 1 ? currentIndex + 1 : 0;

						// Try multiple approaches to change the image
						var newSrc = mediaFiles[newIndex].url;
						
						// Method 1: Direct src change
						mainImg.src = newSrc;
						mainImg.setAttribute("src", newSrc);
						mainImg.setAttribute("data-current-index", newIndex);
						
						// Method 2: Create new image element
						var newImg = document.createElement("img");
						newImg.src = newSrc;
						newImg.className = mainImg.className;
						newImg.id = mainImg.id;
						newImg.setAttribute("data-current-index", newIndex);
						newImg.setAttribute("data-gallery-id", galleryId);
						
						// Copy all attributes
						for (var j = 0; j < mainImg.attributes.length; j++) {
							var attr = mainImg.attributes[j];
							if (attr.name !== "src" && attr.name !== "data-current-index") {
								newImg.setAttribute(attr.name, attr.value);
							}
						}
						
						// Replace the old image with new one
						mainImg.parentNode.replaceChild(newImg, mainImg);
												
						// Update thumbnails
						var thumbnails = document.querySelectorAll('[data-gallery-id="' + galleryId + '"]');
						thumbnails.forEach(function(thumb, index) {
							if (thumb.classList.contains("yta-gallery-thumb")) {
								thumb.classList.toggle("active", index === newIndex);
								thumb.style.border = index === newIndex ? "2px solid #333" : "2px solid transparent";
							}
						});
					} 
				} 
			}
		}
		
		if (e.target.classList.contains("yta-gallery-thumb")) {
			var galleryId = e.target.getAttribute("data-gallery-id");
			var index = parseInt(e.target.getAttribute("data-index"));
			var mediaFiles = JSON.parse(e.target.getAttribute("data-media-files"));
			var mainImg = document.querySelector("#mainImg" + galleryId.replace("gallery", ""));
			
			mainImg.src = mediaFiles[index].url;
			mainImg.setAttribute("data-current-index", index);
			
			// Update thumbnails
			var thumbnails = document.querySelectorAll('[data-gallery-id="' + galleryId + '"]');
			thumbnails.forEach(function(thumb, thumbIndex) {
				if (thumb.classList.contains("yta-gallery-thumb")) {
					thumb.classList.toggle("active", thumbIndex === index);
					thumb.style.border = thumbIndex === index ? "2px solid #333" : "2px solid transparent";
				}
			});
		}
		
		if (e.target == document.querySelector(".yta-modal.is-visible")) {
			//closing when pressed out of modal
			document.querySelector(".yta-modal.is-visible").classList.remove(isVisible2);
		}
	});

	document.addEventListener("scroll", e => {
		if(document.querySelector(".yta-modal.is-visible") && window.innerWidth < 599){
			document.querySelector(".yta-modal.is-visible").classList.remove(isVisible2);		

		}
	});
  

	document.addEventListener("keyup", e => { 
	  if (e.key == "Escape" && document.querySelector(".yta-modal.is-visible")) {
		// if we press the ESC
		document.querySelector(".yta-modal.is-visible").classList.remove(isVisible2);
	  }
	});  
	</script>
