    font-family: 'Josefin Sans', sans-serif !important;
}

#scn_e3ba185484000 {
  
  max-width: 546px;
  margin:0 auto!important;

.sfy-product-container {
    height: 300px;       
    overflow-y: auto;     
    overflow-x: hidden; 
     display: flex;
        flex-wrap: wrap;
        gap: 10px;
        padding: 20px 0; 
}
    .sfy-prd-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100px;
    }

    .sfy-prd-card {
        position: relative;
        width: 80px;  
        height: 80px;
        border: 2px solid #eee;
        border-radius: 15px;   
        overflow: hidden;
        transition: all 0.2s ease-in-out;
        background: #fff;
    }

    .sfy-prd-card:hover {
        border-color: #eb008b;
        transform: translateY(-2px);
    }

    .seg-product-images img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        padding: 8px;
    }

    .sfy-prd-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #eb008b; 
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .sfy-prd-card:hover .sfy-prd-overlay {
        opacity: 1;
    }

    .sfy-prd-overlay-text {
        color: white;
        font-size: 10px;
        text-align: center;
        font-weight: bold;
        padding: 4px;
    }

    .sfy-prd-name-stable {
        margin-top: 10px;
        font-size: 13px;
        font-weight: 600;
        color: #666;
        text-align: center;
        width: 100%;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
}</style><style>.sgm-product-card {
