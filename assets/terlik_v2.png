;position:fixed;z-index:999999;left:0;top:0;width:100%;height:100%;overflow:auto;background-color:rgba(0,0,0,0.4)}.yt-publish-modal-content{background-color:#fefefe;margin:5% auto;padding:20px;border:none;border-radius:8px;width:80%;max-width:600px;max-height:80vh;overflow-y:auto;position:relative}.yt-publish-modal-close{color:#666;font-size:28px;font-weight:bold;cursor:pointer;position:absolute;right:-10px;top:-10px;background:white;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,0.15);border:1px solid #ddd}.yt-publish-modal-body{margin-top:30px;line-height:1.6;color:#333}.yt-input-div .comment-label a,.yt-question-input-div .yt-question-comment-label a{display:flex !important}.yt-publish-modal-close-container{position:sticky;top:0;right:0;height:0;z-index:1}#question-answer-main-div .yta-question-list .answer-text{padding-top:10px !important}.ytaNoComment{margin-top:10px !important}
</style><link rel="stylesheet" href="./terlik_files/swiper-bundle.css" data-seg-swiper="css"><script src="./terlik_files/swiper-bundle.min.js.indir" data-seg-swiper="js"></script></head>
  <body class="product-detail-body yt_comment_is_open"><style>.sgm-product-card {
    width: 100%;
}

.sgm-product-miniature {
    display: flex;
    flex-direction: column;
}

.sgm-element-top {
    position: relative;
}

.sgm-badge {
    background: url(data:image/png;base64,);
        height: 73px;
        padding-top: 6px;
        position: absolute;
        right: 8px;
        text-align: center;
        top: 0;
        width: 60px;
        z-index: 1;
        gap: 2px !important;
        display: flex;
        flex-direction: column;
}

.sgm-discount-range{
    color: #fff;
    font-size: 21px;
}

.sgm-discount-badge{
    color: #ffbf55;
    font-size: 10px;
    line-height: 8px;
}

.sgm-product-link {
    display: block;
    text-decoration: none;
}

.sgm-image-wrapper {
    width: 100%;
    background-color: #f5f5f5;
}

.sgm-product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.sgm-element-bottom {
    padding: 0;
}
.sgm-product-brand{
    display: flex;
    justify-content: space-between;
}

.sgm-product-brand a {
    display: block;
    font-size: 16px;
    padding-right: 26px;
    position: relative;
    color: #333;
    font-weight: 700;
    text-decoration: none;
}

.sgm-product-name a {
    color: #333;
    display: block;
    font-size: 16px;
    margin-top: 4px;
    min-height: 45px;
    font-weight: 700;
    text-decoration: none;
}

.sgm-price-container {
    display: flex;
    align-items: baseline;
    justify-content: start;
    gap: 8px;
    flex-wrap: wrap;
    margin-block-start: 4px;
}

.sgm-old-price:empty {
    display: none;
}

.sgm-old-price:not(:empty) {
    font-size: 18px;
    text-decoration: line-through;
    color: #333;
    font-weight: 700;
    line-height: 1;
}

.sgm-price {
    color: #000;
    font-size: 24px;
    font-weight: 700;
    line-height: 1;
}

.sgm-old-price:not(:empty)+.sgm-price {
    color: #eb008b;
}

.sgm-product-card .toggle-favourite{
    font-size:  20px !important;
}


@media (max-width: 768px) {

    .sgm-product-name a,
    .sgm-product-brand a {
        font-size: 14px;
    }

    .sgm-price {
        font-size: 18px;
    }

    .sgm-old-price:not(:empty) {
        font-size: 16px;
    }

    .sgm-badge {
        height: 54px;
        width: 44px;
        right: 6px;
        padding-top: 4px;
        background-size: 44px 54px;
    }

    .sgm-discount-range {
        font-size: 13px;
    }

    .sgm-discount-badge {
        font-size: 8px;
        line-height: 7px;
    }
}</style><style>
#scn_e2c5fab28e000{
  display: none;
  position: relative;
  margin: 10px auto;
  max-width: 1180px
  font-family: josefin_sans, sans-serif;
}

#scn_e2c5fab28e000 .sgf-title{
    font-size: 22px;
    justify-content: flex-start;
    display: flex;
    margin-bottom: 13px;
}

/* SWIPER Settings */
:root {
    --sgf-swp-arrow-color: #fff;
    --sgf-swp-arrow-background: #eb008b;
    --sgf-swp-arrow-box-shadow: none;
    --sgf-swp-arrow-distance: 0;
    --sgf-swp-arrow-font-size: 16px;
    --sgf-swp-arrow-width: 30px;
    --sgf-swp-arrow-height: 30px;
    --sgf-swp-pagination-size: 4px;
    --sgf-swp-pagination-active-color: var(--sgf-swp-arrow-color);
    --sgf-swp-pagination-passive-color: var(--sgf-swp-pagination-active-color);
}
#scn_e2c5fab28e000 .swiper-wrapper {
    padding: 0;
}
#scn_e2c5fab28e000 .swiper-pagination {
    display: none;
    position: absolute !important;
    bottom: 10px !important;
    top: unset !important;
    left: 0 !important;
    width: 100% !important;
    z-index: 1 !important;
}

#scn_e2c5fab28e000 .swiper-pagination-bullet {
    background: var(--sgf-swp-pagination-passive-color) !important;
    width: calc(var(--sgf-swp-pagination-size) / 2);
    height: calc(var(--sgf-swp-pagination-size) / 2);
    transform: translateY(50%);
}

#scn_e2c5fab28e000 .swiper-pagination-bullet-active {
    background: var(--sgf-swp-pagination-active-color) !important;
    width: var(--sgf-swp-pagination-size);
    height: var(--sgf-swp-pagination-size);
}

#scn_e2c5fab28e000 .swiper-button-prev,
#scn_e2c5fab28e000 .swiper-button-next {
    margin-top: 1rem;
    color: var(--sgf-swp-arrow-color) !important;
    width: var(--sgf-swp-arrow-width) !important;
    height: var(--sgf-swp-arrow-height) !important;
    background-color: var(--sgf-swp-arrow-background) !important;
    pointer-events: all !important;
    z-index: 1 !important;
    box-shadow: var(--sgf-swp-arrow-box-shadow) !important;
}

#scn_e2c5fab28e000 .swiper-button-prev{
    left: var(--sgf-swp-arrow-distance) !important;
}

#scn_e2c5fab28e000 .swiper-button-next{
    right: var(--sgf-swp-arrow-distance) !important;
}

#scn_e2c5fab28e000 .swiper-button-prev:after,
#scn_e2c5fab28e000 .swiper-button-next:after {
    font-size: var(--sgf-swp-arrow-font-size) !important;
}


 #scn_e32c12222c000,
 #scn_e32c13c43a000{
    margin-inline: 20px;
 }
@media (max-width: 768px){
    .sgm-product-name a {
    font-size:11px !important;
    }
    #scn_e2c5fab28e000 .sgf-title {
        font-size: 18px;
    }
#scn_e2c5fab28e000{
        margin-inline: 18px;
    }

#scn_e2c5fab28e000 .swiper-button-prev{
    left: -21px !important;
}

#scn_e2c5fab28e000 .swiper-button-next{
    right: -21px !important;
}
