<script>
  function applyWebOzelStyleWhenReady() {
    const webOzel = document.querySelector(".web-ozel-prod");
    if (!webOzel) return;

    // CSS kurallarını ekle (TL'ye ayrı boyut!)
    const style = document.createElement("style");
    style.textContent = `
          /* Ana fiyat alanları */
          #mobilePrice,
          .product-list__price,
          .product-list__currency {
              color: #999 !important;
              font-weight: bold !important;
              font-size: 15px !important;
              line-height: 1 !important;
          }

          /* TL kısmı (span) için daha küçük boyut */
          #mobilePrice span,
          .basketMobile_price span,
          .product-list__currency span {
              color: #999 !important;
              font-weight: bold !important;
              font-size: 12px !important;
          }
      `;
    document.head.appendChild(style);

    // Hemen varsa uygula
    const applyNow = () => {
      document
        .querySelectorAll(
          "#mobilePrice, .product-list__price, .product-list__currency, .basketMobile_price span",
        )
        .forEach((el) => el.classList.add("webOzelFiyat"));
    };
    applyNow();

    // Sonradan DOM’a eklense yakala
    const observer = new MutationObserver(() => {
      const mp = document.getElementById("mobilePrice");
      if (mp) {
        applyNow();
        //  console.log("✅ Web'e Özel bulundu — TL font küçültüldü, stiller uygulandı.");
        observer.disconnect();
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });
  }

  applyWebOzelStyleWhenReady();
</script>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    if (window.location.pathname === "/") {
      document
        .querySelector(".navbar-toggle")
        ?.addEventListener("click", function () {
          document.querySelector(".search")?.classList.remove("hide");
          document.querySelector(".search__button")?.classList.remove("hide");
          document
            .querySelector(".navbar-header__content")
            ?.classList.remove("no-padding");
        });
    }
  });
</script>

