<script>
  window["isUserHasAuthCookie"] = "undefined";
  var name = "brandcategory.product-detail";
  var loc = window.location.pathname;
  var stateHistory = [];

  try {
    stateHistory = JSON.parse(sessionStorage.getItem("stateHistory")) || [];
    sessionStorage.setItem(
      "previousPageUrlData",
      JSON.stringify(stateHistory.at(-1) || {})
    );
  } catch (e) {}

  if (
    stateHistory.length === 0 ||
    (stateHistory.length > 0 &&
      stateHistory[stateHistory.length - 1].href !== window.location.href)
  ) {
    stateHistory.push({
      name,
      location: loc,
      page_type: "product_detail",
      hash: window.location.hash,
      href: window.location.href,
      pathname: window.location.pathname,
      search: window.location.search,
    });
  }

  try {
    sessionStorage.setItem("stateHistory", JSON.stringify(stateHistory));
  } catch (e) {}
</script>


